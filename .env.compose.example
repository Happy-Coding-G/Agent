# Docker Compose infrastructure credentials
# Copy this file to .env.compose and fill in strong values before running:
#   docker compose --env-file .env.compose up -d
#
# ⚠️  NEVER commit real credentials to version control.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_pg_password
POSTGRES_DB=dataspace

# MinIO object storage
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password

# Neo4j (format: user/password)
NEO4J_AUTH=neo4j/CHANGE_ME_strong_neo4j_password
NEO4J_PASSWORD=CHANGE_ME_strong_neo4j_password

# SSL mode for PostgreSQL connections (use 'require' for production)
DB_SSLMODE=disable

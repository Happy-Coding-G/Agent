    "/api/v1/spaces/{space_id}/tree": {
      "get": {
        "tags": [
          "upload",
          "File Management"
        ],
        "summary": "Get Space Tree",
        "description": "获取指定空间的完整目录树\n算法逻辑：\n1. 一次性查询空间下所有 Folder 和 File\n2. 使用内存映射表（Map）将扁平数据组装成递归嵌套结构",
        "operationId": "get_space_tree_api_v1_spaces__space_id__tree_get",
        "security": [
          {
            "OAuth2PasswordBearer": []
          }
        ],
        "parameters": [

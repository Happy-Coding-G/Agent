# =============================================================================
# Agent Data Space Platform — Environment Variables
# =============================================================================
# Copy this file to backend/app/.env (or export vars in your shell) and fill in
# the values for your environment.
#
#   cp backend/.env.example backend/app/.env
#
# IMPORTANT: Never commit the real .env file to version control.
# =============================================================================

# ---- Database (PostgreSQL) --------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DB_SSLMODE=disable
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=40
# READ_REPLICA_URL=

# ---- MinIO (S3-compatible object storage) -----------------------------------
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False

# ---- LLM / Embeddings ------------------------------------------------------
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

QWEN_API_KEY=sk-your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_EMBEDDING=text-embedding-v2

# ---- Remote Embedding / Rerank (self-hosted, optional) ----------------------
REMOTE_EMBEDDING_ENABLED=False
REMOTE_EMBEDDING_BASE_URL=http://localhost:27701
REMOTE_EMBEDDING_MODEL=Qwen3-Embedding-4B

REMOTE_RERANK_ENABLED=False
REMOTE_RERANK_BASE_URL=http://localhost:29639
REMOTE_RERANK_MODEL=Qwen3-Reranker-4B

# ---- Neo4j (knowledge graph) -----------------------------------------------
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ---- Redis / Celery ---------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---- Security ---------------------------------------------------------------
# Generate a strong key:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE-ME-generate-a-real-secret-with-python-c-import-secrets-print-secrets-token-urlsafe-64
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- CORS -------------------------------------------------------------------
# Comma-separated allowed origins for the frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
